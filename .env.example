POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=change-me-to-a-random-64-char-string
FRONTEND_BASE_URL=http://your-domain.example
JWT_REFRESH_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# This deploy stack now serves plain HTTP only.
# If you later put the app behind an HTTPS reverse proxy, switch these back:
# FRONTEND_BASE_URL=https://your-domain.example
# JWT_REFRESH_COOKIE_SECURE=true

# First production boot on a brand-new database only.
# Remove these after the first successful deploy once the admin account exists.
APP_BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.example
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-admin-password
APP_BOOTSTRAP_ADMIN_FULL_NAME=System Admin
APP_BOOTSTRAP_ADMIN_PHONE=
